name: vidmate_clone_app
description: A functional MVP Media Downloader and Player application.
publish_to: 'none'

version: 1.0.0+1

environment:
  sdk: '>=3.0.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter

  # State Management & Dependency Injection
  riverpod: ^2.3.7
  flutter_riverpod: ^2.3.7
  riverpod_annotation: ^2.2.0
  riverpod_generator: ^2.3.0

  # Local Storage (Using Isar for MVP)
  isar: ^3.1.0
  isar_flutter_libs: ^3.1.0

  path_provider: ^2.1.1

  # Webview and Network Interception
  flutter_inappwebview: ^6.0.0 # Use a stable version

  # HTTP Client
  dio: ^5.3.0

  # Media Processing
  ffmpeg_kit_flutter_new: ^4.1.0
  # File Handling
  file_picker: ^6.1.1

  # Video Player
  video_player: ^2.7.0
  chewie: ^1.7.0

  # Utility
  intl: ^0.18.1
  equatable: ^2.0.5
  fpdart: ^1.1.0

  # Image Loading
  cached_network_image: ^3.3.0

  # YouTube Parsing
  youtube_explode_dart: ^1.12.0 # Use latest stable

  # Permissions Handling (Essential for runtime permissions)
  permission_handler: ^10.4.3


dev_dependencies:
  flutter_test:
    sdk: flutter

  flutter_lints: ^2.0.0
  isar_generator: ^3.1.0
  build_runner: ^2.4.6
  flutter_gen_runner: ^5.4.0 # Useful for asset management if needed


flutter:
  uses-material-design: true
  assets:
    - assets/icons/
